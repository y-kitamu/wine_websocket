<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <!-- Allow catch blocks to catch AccessViolationException (a Corrupted State
         Exception by default in .NET 4). Needed to observe the failure. -->
    <legacyCorruptedStateExceptionsPolicy enabled="true" />
  </runtime>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
  </startup>
</configuration>
